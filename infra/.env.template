# copy to infra/.env and fill in real values. .env is gitignored.

POSTGRES_USER=datastream
POSTGRES_PASSWORD=changeme
POSTGRES_DB=datastream
DATABASE_URL=postgresql://datastream:changeme@postgres:5432/datastream

LOG_FORMAT=json

DOMAIN=localhost

# api auth: comma-separated label:sha256hex pairs. the server refuses to start
# if this is empty. generate a key + its env line with:
#   cd builders/server && uv run python -m core.auth generate <label>
# only the hash goes here; hand the raw key to the client.
API_KEYS=default:<sha256hex>

# dataset proposals: fine-grained pat of the bot account, scoped to only the
# datastream repo with Contents + Pull requests read/write. used by
# POST /datasets to open dataset-proposal prs. without it, dataset creation
# returns 502; everything else works.
GITHUB_TOKEN=<bot-pat>
# GITHUB_REPO=Wat-Street/datastream
# GITHUB_API_URL=https://api.github.com
# github logins auto-requested as reviewers on proposal prs (best-effort)
# GITHUB_REVIEWERS=Blackgaurd,Scr4tch587

# copy to infra/.env and fill in real values (infra/.env is gitignored)

# --- postgres ---
POSTGRES_USER=datastream
POSTGRES_PASSWORD=changeme
POSTGRES_DB=datastream

# --- builder service ---
DATABASE_URL=postgresql://datastream:changeme@postgres:5432/datastream

# --- caddy ---
# production: your real domain (caddy auto-provisions a let's encrypt cert)
# local docker: "localhost" (self-signed) or ":80" (plain http)
DOMAIN=localhost

# --- api auth ---
# comma-separated name=secret pairs; each client gets its own key so keys can be
# rotated/revoked independently and traffic is labeled by client in logs.
# generate secrets with e.g. `openssl rand -hex 32`.
DATASTREAM_API_KEYS=frontend=replace-me,sdk=replace-me
# set to true to bypass auth entirely (local dev only; never in production)
# DATASTREAM_AUTH_DISABLED=false
